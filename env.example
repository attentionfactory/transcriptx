# TranscriptX Environment Variables
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
SECRET_KEY=generate_a_random_string_here

# ── Polar (payments) ──────────────────────────
# Get these from your Polar dashboard after creating products
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
POLAR_STARTER_PRODUCT_ID=your_starter_product_id
POLAR_PRO_PRODUCT_ID=your_pro_product_id

# Optional annual variants (10x monthly = 2 months free). Leave blank until
# you create the recurring-annual products in Polar, then paste the IDs.
POLAR_STARTER_ANNUAL_PRODUCT_ID=
POLAR_PRO_ANNUAL_PRODUCT_ID=

# Polar checkout URLs (create these in Polar dashboard)
POLAR_CHECKOUT_STARTER=https://polar.sh/checkout/your-starter-link
POLAR_CHECKOUT_PRO=https://polar.sh/checkout/your-pro-link
POLAR_CUSTOMER_PORTAL=https://polar.sh/your-org/portal

# Optional annual checkout URLs (fall back to monthly when unset).
POLAR_CHECKOUT_STARTER_ANNUAL=
POLAR_CHECKOUT_PRO_ANNUAL=

# Optional win-back checkout URLs emailed to revoked subscribers (create in
# Polar with a one-time 50% coupon applied). Fall back to the normal checkout
# URLs above when unset.
POLAR_CHECKOUT_WINBACK_STARTER=
POLAR_CHECKOUT_WINBACK_PRO=

# ── Database ──────────────────────────────────
# On Railway, mount a volume at /data and set:
DB_PATH=/data/transcriptx.db

# ── Resend (email OTP) ───────────────────────
# Get a free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=TranscriptX <noreply@yourdomain.com>

# ── Admin ─────────────────────────────────────
ADMIN_EMAILS=you@youremail.com

# ── App ───────────────────────────────────────
FLASK_ENV=production
PORT=5000

# ── yt-dlp / YouTube reliability ──────────────
# Optional. Single proxy URL or comma-separated proxy pool.
# Example:
# YTDLP_PROXY_URL=http://user:pass@p.webshare.io:80
# YTDLP_PROXY_URL=http://u1:p1@host1:80,http://u2:p2@host2:80
YTDLP_PROXY_URL=
